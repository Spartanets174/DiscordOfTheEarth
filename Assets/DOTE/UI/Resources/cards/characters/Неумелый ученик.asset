  passiveAbility: "\"\u042F \u043C\u043E\u0433\u0443\" \u0441 \u0448\u0430\u043D\u0441\u043E\u043C
    \u0432 15% \u043C\u043E\u0436\u0435\u0442 \u0430\u0442\u043E\u043A\u0430\u0432\u0430\u0442\u044C
    \u043D\u0435 \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u0432 \u043E\u0447\u043A\u0438
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F"
  attackAbility: "\"\u041B\u0443\u0447\u0448\u0438\u0439 \u043F\u0440\u0438\u0435\u043C!\"
    \u0432\u043B\u0438\u044F\u0435\u0442 \u043D\u0430 \u043C\u0435\u043B\u043A\u0438\u0439
    \u043C\u0435\u0442\u0430\u043B\u043B \u0440\u044F\u0434\u043E\u043C \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u044F
    \u0438\u0437 \u043D\u0435\u0433\u043E \u0447\u0442\u043E-\u0442\u043E \u0432\u0440\u043E\u0434\u0435
    \u043D\u043E\u0436\u0435\u0439 \u0438 \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0435\u0442
    \u0438\u0445 \u0432\u043E \u0432\u0440\u0430\u0433\u0430 1(100)\u0435\u0434 \u0443\u0440\u043E\u043D\u0430"
  defenceAbility: "\"\u0422\u044B \u043C\u043E\u0439\" \u0421\u043E\u0431\u0438\u0440\u0430\u0435\u0442
    \u043C\u0435\u0442\u0430\u043B\u043B \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u0435\u0442
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u043E\u044E\u0437\u043D\u043E\u0433\u043E
    \u044E\u043D\u0438\u0442\u0430 \u0438\u043B\u0438 \u0441\u0435\u0431\u044F \u0447\u0442\u043E-\u0442\u043E
    \u0432\u0440\u043E\u0434\u0435 \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0439
    \u0434\u0435\u0432\u044B \u0438 \u043F\u043E\u0432\u044B\u0448\u0430\u0435\u0442
    \u0435\u0433\u043E \u0424\u0438\u0437.\u0417\u0430\u0449\u0438\u0442\u0443 \u043D\u0430
    +2\u0435\u0434 (\u0414\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442 2 \u0445\u043E\u0434\u0430)"
  buffAbility: "\"\u0412\u043F\u0435\u0440\u0435\u0434\" \u0414\u0432\u0438\u0433\u0430\u0435\u0442
    \u0441\u043E\u044E\u0437\u043D\u043E\u0433\u043E \u044E\u043D\u0438\u0442\u0430
    \u043D\u0430 \u043E\u0434\u043D\u0443 \u043A\u043B\u0435\u0442\u043A\u0443 \u043D\u0430\u0437\u0430\u0434\u0438
    \u043D\u043E \u0434\u0430\u0435\u0442 \u0435\u043C\u0443 +1\u0435\u0434 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438"
